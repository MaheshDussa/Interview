@WebApplication1_HostAddress = http://localhost:5093
@BearerToken = replace-me

GET {{WebApplication1_HostAddress}}/weatherforecast/
Accept: application/json

###

POST {{WebApplication1_HostAddress}}/api/practice/azure/event-grid
Authorization: Bearer {{BearerToken}}
Content-Type: application/json

{
	"subject": "practice/tasks",
	"eventType": "Practice.TaskCreated",
	"payloadJson": "{\"taskId\":101,\"source\":\"practice\"}"
}

###

POST {{WebApplication1_HostAddress}}/api/practice/azure/event-hub
Authorization: Bearer {{BearerToken}}
Content-Type: application/json

{
	"message": "event hub practice message",
	"partitionKey": "team1"
}

###

POST {{WebApplication1_HostAddress}}/api/practice/azure/service-bus
Authorization: Bearer {{BearerToken}}
Content-Type: application/json

{
	"message": "service bus practice message",
	"messageId": "msg-1001",
	"correlationId": "corr-1001",
	"subject": "Practice.OrderCreated"
}

###

POST {{WebApplication1_HostAddress}}/api/practice/azure/queue-storage
Authorization: Bearer {{BearerToken}}
Content-Type: application/json

{
	"message": "queue storage practice message"
}

###
